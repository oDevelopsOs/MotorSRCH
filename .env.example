# Copy to .env and adjust
#
# En VPS usa Docker Engine (no Podman): `docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile searxng up -d --build`
#
# --- Antes de servidor / VPS (recomendado) ---
# 1) Cambia POSTGRES_PASSWORD y MEILI_MASTER_KEY (no uses valores de ejemplo en producción).
# 2) Para /resolve con meta-búsqueda web: perfil compose `searxng` + variables abajo.
#    Levantar: docker compose --profile searxng up -d   o   .\scripts\start-all.ps1 -ComposeProfile searxng
# 3) Tras el arranque: .\scripts\smoke-stack.ps1 (o bash scripts/smoke-stack.sh en Linux).
# 4) Primera ejecución: descarga de modelos Hugging Face (volumen hf_cache); puede tardar varios minutos.

POSTGRES_USER=motor
POSTGRES_PASSWORD=motor
POSTGRES_DB=motor

MEILI_MASTER_KEY=dev_master_key_change_me

# API
CORS_ORIGINS=*
# Resolve pipeline: ENABLE_RERANK=1 ENABLE_SYNTHESIS=1 USE_OLLAMA_FOR_PLAN=1
# OLLAMA_URL=http://host.docker.internal:11434
# GROQ_API_KEY=

# Firecrawl Agent (solo API cloud v2; clave en https://firecrawl.dev)
# FIRECRAWL_AGENT_BASE_URL=https://api.firecrawl.dev
# FIRECRAWL_AGENT_API_KEY=

# OpenPerplex backend opcional (microservicio aparte)
# OPENPERPLEX_URL=http://host.docker.internal:8000

# Vane API opcional (solo HTTP; ajusta path si tu despliegue difiere)
# VANE_API_URL=http://host.docker.internal:3000
# VANE_SEARCH_PATH=api/search

# SearXNG (perfil compose `searxng`, puerto host 8088): meta-búsqueda en /resolve + GET /brain/searxng/search
# Motores y categorías: `searxng/settings.yml` (montado en el contenedor).
# Descomenta el bloque siguiente cuando levantes el servicio searxng (sin esto la API tiene ENABLE_SEARXNG=0 por defecto).
# ENABLE_SEARXNG=1
# SEARXNG_URL=http://searxng:8080
# SEARXNG_MAX_RESULTS=15
# ENABLE_SEARXNG_DECOMPOSITION=1
# SEARXNG_SUBQUERY_TIMEOUT=8
# Sin APIs directas wiki/OpenAlex/Wikidata en /resolve (solo SearXNG + índice local):
# SEARXNG_AS_PRIMARY=1
# Modo híbrido con APIs públicas además de SearXNG:
# SEARXNG_AS_PRIMARY=0

# /resolve?brain_boost=... — tiempo máximo (s) para Firecrawl Agent
# BRAIN_BOOST_MAX_WAIT=90

# Crawler — comma-separated hostnames that need FlareSolverr
FLARE_DOMAINS=

# Crawl4AI (servicio en compose, puerto 11235). Vacío = no usar; "*" = todos los hosts
# CRAWL4AI_URL=http://crawl4ai:11235
# CRAWL4AI_DOMAINS=

# Firecrawl auto-alojado (opcional): el crawler usa SIEMPRE el SDK Go (mendableai/firecrawl-go/v2).
# Si defines FIRECRAWL_URL, el binario debe poder inicializar el SDK (clave vacía → "dummy").
# FIRECRAWL_URL=http://host.docker.internal:3002
# FIRECRAWL_API_KEY=
# FIRECRAWL_DOMAINS=

# Repeat full seed crawl every N minutes (0 = run once and exit)
CRAWL_INTERVAL_MINUTES=0

# Ollama: si la API corre en Docker y Ollama en el host (plan/síntesis)
# OLLAMA_URL=http://host.docker.internal:11434
# Con `podman compose --profile ollama up -d` usa: OLLAMA_URL=http://ollama:11434

# Tor SOCKS proxy (optional), e.g. tor:9050 inside compose profile
TOR_PROXY=

# Proxies HTTP(S) para Colly / curl-impersonate (rotación residencial, datacenter, etc.)
# COLLY_HTTP_PROXY=http://user:pass@host:port
# CURL_HTTP_PROXY=http://user:pass@host:port

# Camoufox bridge (perfil compose `camoufox`): navegador realista self-hosted
# CAMOUFOX_URL=http://camoufox-bridge:8090
# CAMOUFOX_DOMAINS=
# CAMOUFOX_BRIDGE_TOKEN=

# Scrappey (API cloud; requiere clave en https://scrappey.com)
# SCRAPPEY_URL=https://publisher.scrappey.com
# SCRAPPEY_API_KEY=
# SCRAPPEY_DOMAINS=

# Processor — heavy models; set false on low-RAM dev machines
ENABLE_EMBEDDINGS=true
ENABLE_FINBERT=false
ENABLE_TRANSLATION=false
ENABLE_MINHASH=true

# curl-impersonate binary path inside crawler image
CURL_IMPERSONATE_PATH=/usr/local/bin/curl_chrome120

# --- Producción (docker-compose.prod.yml) ---
# NGINX_HOST_PORT=80
# NGINX_LIMIT_REQ_RATE=200r/s
# NGINX_LIMIT_REQ_BURST=100
# NGINX_WORKER_CONNECTIONS=4096
# REDIS_MAXMEMORY=2gb
# NSQ_MAX_IN_FLIGHT=50
# UVICORN_WORKERS=2
# PROCESSOR_WORKERS=2
# API_UPSTREAM_SERVERS=api:8000
# Segunda API (junto con docker-compose.dual-api.yml): API_UPSTREAM_SERVERS=api:8000,api2:8000
# Hugging Face (descargas de modelos; opcional en servidor)
# HF_TOKEN=
# HF_HOME=/root/.cache/huggingface

# FRED (St. Louis Fed) — clave gratuita en https://fred.stlouisfed.org/docs/api/api_key.html
# El crawler inyecta la clave en seeds con api_key= vacío (api.stlouisfed.org).
# FRED_API_KEY=
